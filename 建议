async def dual_model_review(chapter_text: str, canon_rules: dict) -> ReviewReport:
    # 参考模型 A：Qwen3.5（擅长中文流畅度、爽点检测）
    report_a = await call_qwen(build_review_prompt(chapter_text, canon_rules, focus="beat_and_flow"))
    
    # 参考模型 B：DeepSeek（擅长逻辑、反转、结构分析）
    # 注意：这里因为 VRAM 限制，必须先卸载 A 再加载 B
    report_b = await call_deepseek(build_review_prompt(chapter_text, canon_rules, focus="structure_and_twist"))
    
    # 聚合层：不是简单拼接，而是"冲突检测 + 优先级裁决"
    return merge_reports(report_a, report_b)

def merge_reports(a: ReviewReport, b: ReviewReport) -> ReviewReport:
    """
