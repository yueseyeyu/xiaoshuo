# 这就是你的"spawn_subagent"——一个纯函数，不是新Agent
async def analyze_chapter_beat(chapter_text: str, canon_rules: dict) -> BeatReport:
    """独立的上下文：只接收当前章节 + Canon规则，不携带历史对话"""
    prompt = build_beat_prompt(chapter_text, canon_rules)  # 精确控制输入
    response = await call_model(prompt, model="qwen3.5-9b")
    return parse_beat_report(response)  # 返回结构化摘要，不是原始输出
