Python
import json
import hashlib
from pathlib import Path
from typing import List, Dict, Optional

class KnowledgeBrain:
    """简化版 Knowledge-Brain，实现核心功能"""
    
    def __init__(self, kb_dir: str = "knowledge_brain"):
        self.kb_dir = Path(kb_dir)
        self.kb_dir.mkdir(exist_ok=True)
        
        self.global_exp_file = self.kb_dir / "global_experience.json"
        self.project_memory_file = self.kb_dir / "project_memory.json"
        
        self.global_exp = self._load_global()
        self.project_memory = self._load_project()
    
    def _load_global(self) -> Dict:
        if self.global_exp_file.exists():
            with open(self.global_exp_file, 'r', encoding='utf-8') as f:
                return json.load(f)
        return {"version": "1.0", "max_entries": 20, "experiences": []}
    
    def _load_project(self) -> Dict:
        if self.project_memory_file.exists():
            with open(self.project_memory_file, 'r', encoding='utf-8') as f:
                return json.load(f)
        return {"current_project": "novel-assistant", "local_experiences": []}
    
    def _save(self):
        with open(self.global_exp_file, 'w', encoding='utf-8') as f:
            json.dump(self.global_exp, f, ensure_ascii=False, indent=2)
        with open(self.project_memory_file, 'w', encoding='utf-8') as f:
            json.dump(self.project_memory, f, ensure_ascii=False, indent=2)
    
    def _hash(self, text: str) -> str:
        """根因哈希：同一坑不同描述也能识别"""
        # 简化版：取前50字符的hash，实际可用更智能的语义hash
        normalized = text.lower().strip()[:50]
        return hashlib.md5(normalized.encode()).hexdigest()[:12]
    
    def query_before_action(self, task_description: str, scope: str = "all") -> List[Dict]:
        """动手前先查表：查询是否有相关经验"""
        task_hash = self._hash(task_description)
        
        matched = []
        for exp in self.global_exp["experiences"]:
            # 匹配逻辑：hash 相同 或 关键词匹配
            if exp["hash"] == task_hash:
                matched.append(exp)
                continue
            
            # 关键词匹配（简化版）
            keywords = set(task_description.lower().split())
            exp_keywords = set(exp["root_cause"].lower().split() + exp["symptom"].lower().split())
            if len(keywords & exp_keywords) >= 2:
                matched.append(exp)
        
        # 按 severity 排序
        matched.sort(key=lambda x: {"critical": 0, "high": 1, "medium": 2, "low": 3}[x["severity"]])
        
        return matched
    
    def add_experience(self, root_cause: str, symptom: str, solution: str, 
                       scope: str, severity: str = "medium"):
        """添加新经验（项目级）"""
        exp = {
            "id": f"exp-{len(self.global_exp['experiences']) + 1:03d}",
            "hash": self._hash(root_cause),
            "root_cause": root_cause,
            "symptom": symptom,
            "solution": solution,
            "scope": scope,
            "severity": severity,
            "projects_affected": [self.project_memory["current_project"]],
            "promoted_to_global": False,
            "created_at": "2026-06-30",
            "last_triggered": "2026-06-30"
        }
        
        self.project_memory["local_experiences"].append(exp)
        self._save()
        
        return exp
    
    def promote_to_global(self, exp_id: str) -> bool:
        """项目收尾时：将重复出现的经验升级为全局"""
        # 查找项目级经验
        local_exp = None
        for exp in self.project_memory["local_experiences"]:
            if exp["id"] == exp_id:
                local_exp = exp
                break
        
        if not local_exp:
            return False
        
        # 检查是否已在全局
        for ge in self.global_exp["experiences"]:
            if ge["hash"] == local_exp["hash"]:
                # 已存在，更新 projects_affected
                if self.project_memory["current_project"] not in ge["projects_affected"]:
                    ge["projects_affected"].append(self.project_memory["current_project"])
                ge["last_triggered"] = "2026-06-30"
                self._save()
                return True
        
        # 检查全局表是否已满
        if len(self.global_exp["experiences"]) >= self.global_exp["max_entries"]:
            # 自动降级：删除最久未触发的
            self.global_exp["experiences"].sort(
                key=lambda x: x.get("last_triggered", "1970-01-01")
            )
            self.global_exp["experiences"].pop(0)
        
        # 升级为全局
        local_exp["promoted_to_global"] = True
        self.global_exp["experiences"].append(local_exp)
        self._save()
        
        return True
    
    def get_context_for_prompt(self, task: str, scope: str = "all") -> str:
        """生成给 AI 的上下文提示"""
        matched = self.query_before_action(task, scope)
        
        if not matched:
            return ""
        
        context = "## ⚠️ 历史经验提醒（Knowledge-Brain）\n\n"
        for exp in matched[:3]:  # 最多3条，避免膨胀
            context += f"### [{exp['severity'].upper()}] {exp['symptom']}\n"
            context += f"- **根因**：{exp['root_cause']}\n"
            context += f"- **解法**：{exp['solution']}\n"
            context += f"- **影响项目**：{', '.join(exp['projects_affected'])}\n\n"
        
        return context
