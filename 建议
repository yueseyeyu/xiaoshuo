class NovelIndex:
    def auto_archive(self, current_chapter: int, threshold: int = 50):
        """
        自动休眠整理：超过 threshold 章未引用的设定/伏笔自动归档
        避免记忆膨胀，保持上下文精简
        """
        for entity in self.entities.values():
            if entity.last_appearance < current_chapter - threshold:
                entity.lifecycle_status = "dormant"
                # 但保留在索引中，只是标记为"休眠"
                # S3 评审时，休眠实体不加载到上下文，除非显式查询
        
        for hook in self.foreshadowing:
            if hook.planted_at < current_chapter - threshold and not hook.resolved:
                hook.status = "abandoned"  # 超过 50 章未回收 → 自动废弃
                # 避免 S3 评审时反复警告"旧伏笔未回收"
