    def check_decay(self, chapter_distance: int) -> List[str]:
        """
        检查记忆衰减：
        - 伏笔超过 20 章未回收 → 警告读者可能已遗忘
        - 超过 50 章未回收 → 建议废弃或强制回收
        """
        warnings = []
        for hook in self.active_hooks:
            if chapter_distance - hook["planted_at"] > 50:
                warnings.append(f"伏笔 '{hook['name']}' 已埋 {chapter_distance - hook['planted_at']} 章，建议废弃或回收")
            elif chapter_distance - hook["planted_at"] > 20:
                warnings.append(f"伏笔 '{hook['name']}' 已埋 {chapter_distance - hook['planted_at']} 章，回收时需前情提要")
        return warnings
