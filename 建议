from dataclasses import dataclass
from typing import List, Dict, Optional, Set
from enum import Enum
import sqlite3
import json

class EventType(Enum):
    PLOT = "plot"           # 剧情事件（战斗、对话、决策）
    CHARACTER_ARC = "arc"   # 人物弧光事件（成长、堕落、觉醒）
    FORESHADOWING = "hook"  # 伏笔事件（埋钩、回收、废弃）
    EMOTION = "emotion"   # 情绪事件（高潮、低谷、转折）
    SETTING = "setting"     # 设定事件（世界观揭示、规则变更）

@dataclass
class Entity:
    """实体：人物、地点、组织、物品、概念"""
    id: str
    name: str
    type: str  # character, location, organization, item, concept
    aliases: List[str]  # 别名（如"林逸"="主角"）
    canon_properties: Dict  # Canon 设定属性
    first_appearance: int  # 首次出场章节号
    lifecycle_status: str  # active, dead, dormant, unintroduced

@dataclass
class Event:
    """事件：小说中的语义单元"""
    id: str
    chapter_id: int
    event_type: EventType
    content: str  # 事件摘要（200字以内）
    entities: List[str]  # 关联的实体 ID 列表
    timestamp: str  # 叙事时间（非章节号，支持倒叙/插叙）
    emotional_valence: float  # 情绪值 -1.0 ~ 1.0
    importance: int  # 1-10，叙事权重
    related_events: List[str]  # 显式关联的事件 ID（伏笔回收等）

class NovelSAG:
    """小说版 SAG：事件-实体索引与动态超边"""
    
    def __init__(self, db_path: str = "novel_sag.db"):
        self.conn = sqlite3.connect(db_path)
        self._init_schema()
    
    def _init_schema(self):
        """初始化 SQL 表结构"""
        self.conn.executescript("""
            CREATE TABLE IF NOT EXISTS entities (
                id TEXT PRIMARY KEY,
                name TEXT NOT NULL,
                type TEXT NOT NULL,
                aliases TEXT,  -- JSON array
                canon_properties TEXT,  -- JSON
                first_appearance INTEGER,
                lifecycle_status TEXT,
                last_updated INTEGER
            );
            
            CREATE TABLE IF NOT EXISTS events (
                id TEXT PRIMARY KEY,
                chapter_id INTEGER NOT NULL,
                event_type TEXT NOT NULL,
                content TEXT NOT NULL,
                entities TEXT,  -- JSON array of entity IDs
                timestamp TEXT,
                emotional_valence REAL,
                importance INTEGER,
                related_events TEXT,  -- JSON array
                created_at INTEGER
            );
            
            CREATE TABLE IF NOT EXISTS entity_event_index (
                entity_id TEXT,
                event_id TEXT,
                chapter_id INTEGER,
                role_in_event TEXT,  -- protagonist, antagonist, witness, mentioned
                PRIMARY KEY (entity_id, event_id),
                FOREIGN KEY (entity_id) REFERENCES entities(id),
                FOREIGN KEY (event_id) REFERENCES events(id)
            );
            
            -- 加速查询的索引
            CREATE INDEX IF NOT EXISTS idx_event_chapter ON events(chapter_id);
            CREATE INDEX IF NOT EXISTS idx_event_type ON events(event_type);
            CREATE INDEX IF NOT EXISTS idx_entity_type ON entities(type);
            CREATE INDEX IF NOT EXISTS idx_entity_lifecycle ON entities(lifecycle_status);
        """)
        self.conn.commit()
    
    def add_event(self, event: Event):
        """添加事件，自动维护实体-事件索引"""
        # 插入事件
        self.conn.execute("""
            INSERT OR REPLACE INTO events 
            (id, chapter_id, event_type, content, entities, timestamp, 
             emotional_valence, importance, related_events, created_at)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """, (
            event.id, event.chapter_id, event.event_type.value, event.content,
            json.dumps(event.entities), event.timestamp, event.emotional_valence,
            event.importance, json.dumps(event.related_events), 
            int(time.time())
        ))
        
        # 维护实体-事件反向索引
        for entity_id in event.entities:
            # 推断实体在事件中的角色（简化版）
            role = self._infer_role(entity_id, event)
            self.conn.execute("""
                INSERT OR REPLACE INTO entity_event_index 
                (entity_id, event_id, chapter_id, role_in_event)
                VALUES (?, ?, ?, ?)
            """, (entity_id, event.id, event.chapter_id, role))
        
        self.conn.commit()
    
    def query_character_arc(self, character_id: str, 
                           from_chapter: int = 0, 
                           to_chapter: int = 999999) -> List[Event]:
        """
        查询人物弧光：SAG 的核心查询
        通过 SQL JOIN 动态构建人物的事件链，不是遍历全量
        """
        cursor = self.conn.execute("""
            SELECT e.* FROM events e
            JOIN entity_event_index ei ON e.id = ei.event_id
            WHERE ei.entity_id = ?
            AND e.chapter_id BETWEEN ? AND ?
            AND e.event_type IN ('arc', 'plot', 'emotion')
            ORDER BY e.chapter_id, e.timestamp
        """, (character_id, from_chapter, to_chapter))
        
        return [self._row_to_event(row) for row in cursor.fetchall()]
    
    def query_foreshadowing_status(self, hook_id: str) -> Dict:
        """
        查询伏笔状态：埋钩 → 关联事件 → 是否回收
        SAG 多跳推理：hook 事件 → 相关事件 → 检查回收
        """
        # 第一跳：找到伏笔事件
        hook_event = self.conn.execute("""
            SELECT * FROM events WHERE id = ? AND event_type = 'hook'
        """, (hook_id,)).fetchone()
        
        if not hook_event:
            return {"status": "not_found"}
        
        # 第二跳：找到相关事件（通过 related_events 或共享实体）
        hook_entities = json.loads(hook_event[4])  # entities column
        
        # 动态超边：通过共享实体找到可能回收伏笔的事件
        placeholders = ','.join('?' * len(hook_entities))
        related_events = self.conn.execute(f"""
            SELECT DISTINCT e.* FROM events e
            JOIN entity_event_index ei ON e.id = ei.event_id
            WHERE ei.entity_id IN ({placeholders})
            AND e.chapter_id > ?
            AND e.importance >= 7  -- 重要事件才可能是回收
            ORDER BY e.chapter_id
        """, (*hook_entities, hook_event[1])).fetchall()  # chapter_id
        
        # 第三跳：检查是否有事件显式标记为回收
        resolved = False
        resolver_event = None
        for event in related_events:
            related_ids = json.loads(event[8])  # related_events
            if hook_id in related_ids:
                resolved = True
                resolver_event = self._row_to_event(event)
                break
        
        return {
            "hook": self._row_to_event(hook_event),
            "planted_at": hook_event[1],
            "status": "resolved" if resolved else "active",
            "resolver_chapter": resolver_event.chapter_id if resolver_event else None,
            "candidate_events": [self._row_to_event(e) for e in related_events[:5]],
            "chapters_since_planted": max(related_events, key=lambda x: x[1])[1] - hook_event[1] if related_events else 0
        }
    
    def query_cross_chapter_consistency(self, entity_id: str, 
                                        check_type: str = "lifecycle") -> List[Dict]:
        """
        跨章节一致性检查：SAG 动态超边的核心应用
        检查实体在不同章节中的状态是否矛盾
        """
        # 获取该实体的所有事件，按章节排序
        events = self.query_character_arc(entity_id)
        
        inconsistencies = []
        prev_status = None
        
        for i, event in enumerate(events):
            # 从事件内容推断生命周期状态（简化版，实际可用 NLP）
            inferred_status = self._infer_lifecycle_from_event(event)
            
            if prev_status and inferred_status:
                # 检查状态转换是否合法
                if not self._is_valid_transition(prev_status, inferred_status):
                    inconsistencies.append({
                        "chapter_from": events[i-1].chapter_id,
                        "chapter_to": event.chapter_id,
                        "entity_id": entity_id,
                        "invalid_transition": f"{prev_status} -> {inferred_status}",
                        "event_content": event.content
                    })
            
            prev_status = inferred_status
        
        return inconsistencies
    
    def build_local_context_for_chapter(self, chapter_id: int, 
                                       radius: int = 3) -> Dict:
        """
        为 S3 评审构建局部上下文：只加载相关事件，不是全书
        radius: 向前/向后查找多少章
        """
        # 获取当前章节的所有事件
        current_events = self.conn.execute("""
            SELECT * FROM events WHERE chapter_id = ?
        """, (chapter_id,)).fetchall()
        
        # 提取当前章节的实体
        current_entities = set()
        for event in current_events:
            current_entities.update(json.loads(event[4]))
        
        # 动态超边：查找这些实体在 radius 范围内的事件
        placeholders = ','.join('?' * len(current_entities))
        context_events = self.conn.execute(f"""
            SELECT DISTINCT e.* FROM events e
            JOIN entity_event_index ei ON e.id = ei.event_id
            WHERE ei.entity_id IN ({placeholders})
            AND e.chapter_id BETWEEN ? AND ?
            AND e.chapter_id != ?
            ORDER BY e.chapter_id
        """, (*current_entities, chapter_id - radius, chapter_id + radius, chapter_id)).fetchall()
        
        return {
            "current_chapter_events": [self._row_to_event(e) for e in current_events],
            "context_events": [self._row_to_event(e) for e in context_events],
            "relevant_entities": list(current_entities),
            "context_radius": radius
        }
    
    def _row_to_event(self, row) -> Event:
        return Event(
            id=row[0], chapter_id=row[1], event_type=EventType(row[2]),
            content=row[3], entities=json.loads(row[4]), timestamp=row[5],
            emotional_valence=row[6], importance=row[7], 
            related_events=json.loads(row[8])
        )
    
    def _infer_role(self, entity_id: str, event: Event) -> str:
        """简化版：根据实体在事件内容中的位置推断角色"""
        # 实际可用更复杂的 NLP
        if event.content.startswith(entity_id):
            return "protagonist"
        return "mentioned"
    
    def _infer_lifecycle_from_event(self, event: Event) -> Optional[str]:
        """从事件内容推断生命周期状态（简化版）"""
        content = event.content.lower()
        if "死亡" in content or "牺牲" in content:
            return "dead"
        if "登场" in content or "出现" in content:
            return "active"
        return None
    
    def _is_valid_transition(self, from_status: str, to_status: str) -> bool:
        """检查生命周期状态转换是否合法"""
        valid = {
            "active": ["dead", "dormant", "active"],
            "dead": ["dead"],  # 已死不能复活（除非有设定）
            "dormant": ["active", "dead"],
            "unintroduced": ["active"]
        }
        return to_status in valid.get(from_status, [])
